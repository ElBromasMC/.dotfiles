#!/bin/bash

NIX_SERVICE="nix-service"

if [ -n "$NIX_USER" ]; then
    exec doas -u "$NIX_USER" bash -l -c '
        cd $HOME; \
        exec podman exec -it \
            --user root \
            -w /root \
            -e NIX_REMOTE=daemon \
            "$1" nix-shell -p busybox neovim
    ' bash "$NIX_SERVICE"

else
    exec podman exec -it \
        --user root \
        -w /root \
        -e NIX_REMOTE=daemon \
        "$NIX_SERVICE" nix-shell -p busybox neovim
fi

